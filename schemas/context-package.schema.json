{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/context-package.schema.json",
  "title": "AgentContextPackage",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "objective",
    "task_scope",
    "constraints",
    "inputs",
    "outputs_expected",
    "acceptance_checks",
    "open_risks"
  ],
  "properties": {
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "task_scope": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "constraints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "outputs_expected": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "acceptance_checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "open_risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
