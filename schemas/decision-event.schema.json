{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/decision-event.schema.json",
  "title": "DecisionEvent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "cve_id",
    "decision_type",
    "outcome",
    "rule_version",
    "policy_version",
    "reason_codes",
    "created_at"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "cve_id": {
      "type": "string",
      "pattern": "^CVE-[0-9]{4}-[0-9]{4,}$"
    },
    "decision_type": {
      "type": "string",
      "enum": [
        "classify",
        "enrich",
        "ai_review",
        "policy_resolve",
        "publish",
        "update"
      ]
    },
    "outcome": {
      "type": "string",
      "enum": [
        "publish",
        "suppress",
        "defer",
        "update_candidate",
        "error"
      ]
    },
    "rule_version": {
      "type": "string",
      "minLength": 1
    },
    "policy_version": {
      "type": "string",
      "minLength": 1
    },
    "reason_codes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "ai_advisory_used": {
      "type": "boolean"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
