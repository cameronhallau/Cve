# Copy to the host secret store or environment file referenced by systemd.
# Do not commit real secrets.

CVE_APP_NAME=CVE Intelligence Bot Mk2
CVE_ENVIRONMENT=production

# Core runtime
CVE_DATABASE_URL=postgresql+psycopg://cve_service:REPLACE_ME@127.0.0.1:5432/cve_service
CVE_REDIS_URL=redis://127.0.0.1:6379/0
CVE_RQ_QUEUE_NAME=cve-production
CVE_HEALTH_TIMEOUT_SECONDS=5.0

# AI remains advisory only, but unattended production should still configure it
# so ambiguous enterprise-relevance cases can complete deterministically.
CVE_AI_PROVIDER=openrouter
CVE_AI_MODEL=openai/gpt-5.2
CVE_AI_TIMEOUT_SECONDS=30.0
CVE_AI_MAX_COMPLETION_TOKENS=400
CVE_AI_TEMPERATURE=0.0
CVE_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=REPLACE_ME

# Live public CVE ingestion
CVE_CVE_ORG_DELTA_LOG_URL=https://raw.githubusercontent.com/CVEProject/cvelistV5/main/cves/deltaLog.json
CVE_CVE_ORG_HTTP_TIMEOUT_SECONDS=20.0

# Real publish target
CVE_PUBLISH_TARGET_NAME=x

# Preferred unattended X mode
CVE_X_AUTH_MODE=oauth1_user
CVE_X_API_BASE_URL=https://api.x.com
CVE_X_TIMEOUT_SECONDS=15.0
CVE_X_CONSUMER_KEY=REPLACE_ME
CVE_X_CONSUMER_SECRET=REPLACE_ME
CVE_X_ACCESS_TOKEN=REPLACE_ME
CVE_X_ACCESS_TOKEN_SECRET=REPLACE_ME

# Optional only if you have separately proven a durable OAuth2 user-token lifecycle
# CVE_X_AUTH_MODE=oauth2_bearer
# CVE_X_BEARER_TOKEN=REPLACE_ME
